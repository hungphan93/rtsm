# =============================================================================
# .git-blame-ignore-revs
# =============================================================================
# Danh sách commit "format-only" — blame/log sẽ skip qua, attribute về author
# gốc của dòng code (không phải dev chạy clang-format).
#
# Format: SHA đầy đủ (40 hex chars), 1 commit / dòng. Comment bắt đầu bằng `#`.
#
# Activate cho repo này:
#   git config blame.ignoreRevsFile .git-blame-ignore-revs
#
# GitHub/GitLab tự nhận file nếu commit lên repo — không cần config phía server.
#
# Thêm commit mới:
#   git log --oneline -1               # copy SHA của commit format
#   echo "<full-sha>  # mô tả ngắn" >> .git-blame-ignore-revs
# =============================================================================

